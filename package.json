        "@tsconfig/strictest": "^2.0.8",
        "@types/js-cookie": "^3.0.6",
        "@types/luxon": "^3.7.2",
        "@types/node": "^26.0.1",
        "@types/react": "19.2.17",
        "@types/react-dom": "19.2.3",
        "@types/react-swipeable-views": "^0.13.6",
        "babel-plugin-react-compiler": "^1.0.0",
        "esbuild": "^0.28.1",
        "npm-run-all": "^4.1.5",
        "oxfmt": "^0.56.0",
        "oxlint": "^1.71.0",
        "oxlint-tsgolint": "^0.23.0",
        "serwist": "^9.5.11",
        "typescript": "^6.0.3"
    }
