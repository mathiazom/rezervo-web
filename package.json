    "private": true,
    "type": "module",
    "scripts": {
        "preinstall": "npx only-allow pnpm",
        "dev": "next dev --turbopack",
        "build": "next build",
        "start": "next start",
        "prod": "run-s build start",
        "format": "oxfmt",
