{
    "name": "rezervo-web",
    "version": "0.1.0",
    "private": true,
    "type": "module",
    "scripts": {
        "preinstall": "npx only-allow pnpm",
        "dev": "next dev",
        "build": "next build",
        "start": "next start",
        "prod": "run-s build start",
        "format": "oxfmt",
        "format:check": "oxfmt --check",
        "lint": "oxlint",
        "lint:fix": "oxlint --fix",
        "typecheck": "tsc --noEmit",
        "check": "run-s check:parallel",
        "check:parallel": "run-p format:check lint typecheck",
        "fix": "run-s format lint:fix",
        "review": "run-s check prod"
    },
    "dependencies": {
        "@emotion/cache": "^11.14.0",
