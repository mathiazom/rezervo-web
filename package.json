        "@mui/icons-material": "^9.1.1",
        "@mui/material": "^9.1.2",
        "@mui/material-nextjs": "^9.1.1",
        "@mui/x-date-pickers": "^9.7.0",
        "@serwist/turbopack": "^9.5.11",
        "@tanstack/react-query": "^5.101.2",
        "js-cookie": "^3.0.8",
        "jwt-decode": "^4.0.0",
        "luxon": "^3.7.2",
        "next": "16.2.9",
        "react": "19.2.7",
        "react-device-detect": "^2.2.3",
        "react-dom": "19.2.7",
        "react-dropzone": "^15.0.0",
