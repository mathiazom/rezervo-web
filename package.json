        "@mui/material-nextjs": "^6.4.2",
        "@mui/x-date-pickers": "^7.28.3",
        "@serwist/next": "^9.1.1",
        "@tanstack/react-query": "^5.101.0",
        "js-cookie": "^3.0.5",
        "jwt-decode": "^4.0.0",
        "luxon": "^3.7.1",
        "next": "15.5.7",
        "react": "^19.1.1",
