{
    "name": "rezervo-web",
    "version": "0.1.0",
    "private": true,
    "type": "module",
    "scripts": {
        "preinstall": "npx only-allow pnpm",
        "gen:api": "openapi-typescript ${CONFIG_HOST:-http://localhost:8000}/openapi.json -o src/types/api.d.ts",
        "dev": "vite dev",
        "build": "vite build",
        "start": "node --env-file-if-exists=.env.local .output/server/index.mjs",
        "prod": "run-s build start",
        "format": "oxfmt",
        "format:check": "oxfmt --check",
        "lint": "oxlint",
        "lint:fix": "oxlint --fix",
        "typecheck": "tsc --noEmit",
        "check": "run-s check:parallel",
        "check:parallel": "run-p format:check lint typecheck",
        "fix": "run-s format lint:fix",
        "review": "run-s check prod"
    },
    "dependencies": {
        "@emotion/cache": "^11.14.0",
        "@emotion/react": "^11.14.0",
        "@emotion/styled": "^11.14.1",
        "@fontsource-variable/roboto": "^5.2.10",
        "@khmyznikov/pwa-install": "^0.6.4",
        "@mui/icons-material": "^9.1.1",
        "@mui/material": "^9.1.2",
        "@mui/x-date-pickers": "^9.7.0",
        "@tanstack/react-query": "^5.101.2",
        "@tanstack/react-router": "^1.170.16",
        "@tanstack/react-router-ssr-query": "^1.167.1",
        "@tanstack/react-start": "^1.168.26",
        "js-cookie": "^3.0.8",
        "jwt-decode": "^4.0.0",
        "luxon": "^3.7.2",
        "nitro": "3.0.260610-beta",
        "openapi-fetch": "^0.17.0",
        "openapi-react-query": "^0.5.4",
        "react": "19.2.7",
        "react-dom": "19.2.7",
        "react-dropzone": "^15.0.0",
        "react-oauth2-code-pkce": "^1.24.0",
        "react-snowfall": "^2.4.0",
        "zod": "^4.4.3"
    },
    "devDependencies": {
        "@rolldown/plugin-babel": "^0.2.3",
        "@serwist/vite": "^9.5.11",
        "@serwist/window": "^9.5.11",
        "@tanstack/react-query-devtools": "^5.101.2",
        "@tanstack/react-router-devtools": "^1.167.0",
        "@tsconfig/strictest": "^2.0.8",
        "@types/js-cookie": "^3.0.6",
        "@types/luxon": "^3.7.2",
        "@types/node": "^26.0.1",
        "@types/react": "19.2.17",
        "@types/react-dom": "19.2.3",
        "@types/react-swipeable-views": "^0.13.6",
        "@vitejs/plugin-react": "^6.0.3",
        "babel-plugin-react-compiler": "^1.0.0",
        "npm-run-all": "^4.1.5",
        "openapi-typescript": "^7.13.0",
        "oxfmt": "^0.57.0",
        "oxlint": "^1.72.0",
        "oxlint-tsgolint": "^0.23.0",
        "serwist": "^9.5.11",
        "typescript": "^6.0.3",
        "vite": "^8.1.0"
    }
}
